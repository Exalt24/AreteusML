# AreteusML Environment Configuration

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=areteusml
POSTGRES_PASSWORD=areteusml_dev
POSTGRES_DB=areteusml

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=areteusml

# Model
MODEL_NAME=answerdotai/ModernBERT-base
MODEL_PATH=ml/models/production
ONNX_MODEL_PATH=ml/models/onnx

# Monitoring
EVIDENTLY_WORKSPACE=monitoring/workspace
DRIFT_CHECK_INTERVAL=300

# Dagster
DAGSTER_HOME=/opt/dagster/dagster_home

# Argilla
ARGILLA_API_URL=http://localhost:6900
ARGILLA_API_KEY=argilla.apikey

# GPU
CUDA_VISIBLE_DEVICES=0
